{
  "name": "focus-pulse",
  "version": "1.0.0",
  "main": "electron/main.js",
  "build": {
    "appId": "com.srinivas.focuspulse",
    "productName": "FocusPulse",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "cd renderer && npm run build",
    "start": "electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "framer-motion": "^12.34.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  }
}
